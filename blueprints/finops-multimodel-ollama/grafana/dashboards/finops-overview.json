{
  "title": "FinOps \u2014 Multi-Model Gateway",
  "uid": "finops-overview",
  "schemaVersion": 39,
  "editable": true,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "title": "Summary (live + 30-day history)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Total token spend (30d)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(finops_daily_spend_usd[30d]) or litellm_total_spend)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total tokens (30d)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(finops_daily_tokens_total[30d]) or litellm_total_tokens)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Blended cost / 1k tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(sum_over_time(finops_daily_spend_usd[30d]) or litellm_total_spend) / (sum(sum_over_time(finops_daily_tokens_total[30d]) or litellm_total_tokens) / 1000)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Requests (live)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(litellm_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Spend trend (30-day backfilled history)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Spend by model (daily)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "expr": "sum by (model) (last_over_time(finops_daily_spend_usd[1d]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Spend by team (daily)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "targets": [
        {
          "expr": "sum by (team_alias) (last_over_time(finops_daily_spend_usd[1d]))",
          "legendFormat": "{{team_alias}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Chargeback & budgets",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      }
    },
    {
      "type": "bargauge",
      "title": "Budget utilization by team (spend / monthly budget)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "100 * sum by (team_alias) (sum_over_time(finops_daily_spend_usd[30d]) or litellm_team_spend) / max by (team_alias) (max_over_time(finops_team_budget_usd[30d]))",
          "legendFormat": "{{team_alias}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens by model (daily)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (model) (last_over_time(finops_daily_tokens_total[1d]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Live gateway (real-time LiteLLM \u2014 last 3h)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      }
    },
    {
      "type": "timeseries",
      "title": "Live spend by model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {}
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "sum by (model) (litellm_total_spend)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "timeFrom": "3h"
    },
    {
      "type": "timeseries",
      "title": "Live spend by team",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {}
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "targets": [
        {
          "expr": "sum by (team_alias) (litellm_team_spend)",
          "legendFormat": "{{team_alias}}",
          "refId": "A"
        }
      ],
      "timeFrom": "3h"
    },
    {
      "type": "row",
      "title": "Infrastructure cost (OpenCost)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      }
    },
    {
      "type": "stat",
      "title": "Cluster cost ($/hr)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "expr": "sum(node_total_hourly_cost)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Projected monthly infra $",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 34
      },
      "targets": [
        {
          "expr": "sum(node_total_hourly_cost) * 730",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node cost breakdown ($/hr)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {}
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "targets": [
        {
          "expr": "sum(node_cpu_hourly_cost)",
          "legendFormat": "CPU",
          "refId": "A"
        },
        {
          "expr": "sum(node_ram_hourly_cost)",
          "legendFormat": "RAM",
          "refId": "B"
        }
      ]
    }
  ]
}
