{
  "title": "FinOps \u2014 Multi-Model Gateway",
  "uid": "finops-overview",
  "schemaVersion": 39,
  "editable": true,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "row",
      "title": "Token spend (live \u2014 LiteLLM)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Total token spend (30d)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(litellm_total_spend)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Requests (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(litellm_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Blended cost / 1k tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(litellm_total_spend) / (sum(litellm_total_tokens) / 1000)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(litellm_total_tokens)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Spend by model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (model) (litellm_total_spend)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Spend by team",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (team_alias) (litellm_team_spend)",
          "legendFormat": "{{team_alias}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Chargeback & budgets",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      }
    },
    {
      "type": "bargauge",
      "title": "Budget utilization by team",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "expr": "litellm_budget_utilization{entity_type=\"team\"}",
          "legendFormat": "{{entity_alias}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens by model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum by (model) (litellm_total_tokens)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Historical spend (backfilled)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "type": "timeseries",
      "title": "Daily spend by team",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (team_alias) (finops_daily_spend_usd)",
          "legendFormat": "{{team_alias}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Daily spend by model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (model) (finops_daily_spend_usd)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Infrastructure cost (OpenCost)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "stat",
      "title": "Cluster cost ($/hr)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 33
      },
      "targets": [
        {
          "expr": "sum(node_total_hourly_cost)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Projected monthly infra $",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 33
      },
      "targets": [
        {
          "expr": "sum(node_total_hourly_cost) * 730",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node cost breakdown ($/hr)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "targets": [
        {
          "expr": "sum(node_cpu_hourly_cost)",
          "legendFormat": "CPU",
          "refId": "A"
        },
        {
          "expr": "sum(node_ram_hourly_cost)",
          "legendFormat": "RAM",
          "refId": "B"
        }
      ]
    }
  ]
}